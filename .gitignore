# Python cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/

# Local configuration and secrets
.env
.env.*
!.env.example

# Flask/runtime data
instance/
*.db
*.sqlite
*.sqlite3
*.log
.tmp/

# IDE files
.idea/
.vscode/
.DS_Store

